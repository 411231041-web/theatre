PROJECT_NAME="project_name"
PROJECT_DESCRIPTION="project_description"

# Project metadata
DEBUG=True
SQL_DEBUG=True

# Django application secrets and database credentials
SECRET_KEY=your-secret-key-here

# PostgreSQL database settings for Django
SQL_ENGINE=django.db.backends.postgresql_psycopg2
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres-password
POSTGRES_DB=theatre

# Elasticsearch settings for main app
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200

# ETL pipeline settings
ETL_BATCH_SIZE=100
ETL_POLL_INTERVAL=10
ETL_MAX_RETRIES=5
ETL_INITIAL_BACKOFF=1.0
ETL_MAX_BACKOFF=60.0
ETL_BACKOFF_MULTIPLIER=2.0

# PostgreSQL connection settings for ETL or external services
SQL_HOST=theatre-db
SQL_PORT=5432
SQL_OPTIONS=-c search_path=public,content

# Redis cache settings
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CACHE_EXPIRE=300

# FastAPI service settings
ELASTICSEARCH_FILMS_INDEX=movies
ELASTICSEARCH_GENRES_INDEX=genres
ELASTICSEARCH_PERSONS_INDEX=persons
